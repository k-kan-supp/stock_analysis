# ── データベース ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/stockdb

# ── バックエンド ──────────────────────────────────────────────
# asyncpg ドライバを使用 (uvicorn / SQLAlchemy async 用)
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/stockdb

# ── Outlook SMTP 通知 ─────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your@outlook.com
SMTP_PASSWORD=your-password-or-app-password

# 送信先 (カンマ区切りで複数可)
NOTIFY_TO=dest@example.com

# ── アラート設定 ───────────────────────────────────────────────
# 監視銘柄コード (省略時 = DB の全アクティブ銘柄)
WATCHLIST_CODES=7203,9984,6758,8306,4502

# RSI 閾値
RSI_HIGH=70
RSI_LOW=30

# ── フロントエンド CORS ───────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]
