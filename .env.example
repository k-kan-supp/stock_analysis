# ── データベース ──────────────────────────────────────────────
# fetch_and_populate.py / notify.py 用 (psycopg2 同期ドライバ)
DATABASE_URL=postgresql://user:pass@localhost:5432/stockdb
# backend API 用 (asyncpg 非同期ドライバ)
ASYNC_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/stockdb

# ── Outlook SMTP 通知 ─────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your@outlook.com
SMTP_PASSWORD=your-password-or-app-password

# 送信先 (カンマ区切りで複数可)
NOTIFY_TO=dest@example.com

# ── アラート設定 ───────────────────────────────────────────────
# 監視銘柄コード (省略時 = DB の全アクティブ銘柄)
WATCHLIST_CODES=7203,9984,6758,8306,4502

# RSI 閾値
RSI_HIGH=70
RSI_LOW=30

# 出来高急増アラート: 20日平均出来高の何倍以上を検知するか
VOLUME_SURGE_THRESHOLD=3.0

# 配当落ち日アラート: 何日先まで先読みするか
DIVIDEND_ALERT_DAYS=14

# ── SPC 管理 ───────────────────────────────────────────────────
# 連続上昇/降下/Target超え の検知閾値 (日数)
SPC_THRESHOLD=7
# Target = 前日終値 × 比率 (1.005 = +0.5%)
SPC_TARGET_RATIO=1.005

# ── データ取得 (fetch_and_populate.py) ────────────────────────
# デフォルト取得銘柄 (省略時は内部デフォルト10銘柄)
DEFAULT_FETCH_CODES=7203,9984,6758,8306,4502,6861,9433,8035,6098,4063

# Yahoo Finance リクエスト間隔 (秒): レート制限対策
FETCH_REQUEST_INTERVAL=1.5

# 株価属性・TOPIX データの取得期間 (yfinance period 形式: 1y / 2y 等)
FETCH_HISTORY_PERIOD=1y

# 平均出来高の計算窓 (日数)
FETCH_AVG_VOLUME_WINDOW=20

# テクニカル指標のウォームアップ日数 (MA200 等の安定化に必要)
FETCH_WARMUP_BUFFER_DAYS=250

# ── フロントエンド CORS ───────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]
